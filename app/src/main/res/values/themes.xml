<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.IPTV" parent="Theme.AppCompat.NoActionBar">
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowBackground">#0A0A0A</item>
        <item name="android:statusBarColor">#0A0A0A</item>
        <item name="android:navigationBarColor">#0A0A0A</item>
    </style>

    <style name="Lbl">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">#6b7280</item>
        <item name="android:textSize">12sp</item>
        <item name="android:layout_marginTop">10dp</item>
        <item name="android:layout_marginBottom">4dp</item>
    </style>

    <style name="Field">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:padding">12dp</item>
        <item name="android:textColor">#f3f4f6</item>
        <item name="android:textColorHint">#4b5563</item>
        <item name="android:background">@drawable/bg_input</item>
        <item name="android:singleLine">true</item>
        <item name="android:textDirection">ltr</item>
        <item name="android:gravity">start</item>
    </style>
</resources>

